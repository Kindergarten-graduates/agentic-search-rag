# Copy to `.env` and fill in. `.env` is gitignored — keep your real key there.
# The offline default (StubLLM) needs NONE of this.

LLM_BACKEND=openai

# --- DeepSeek (hosted) ---
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat          # or deepseek-reasoner (R1) — see README caveat

# --- vLLM on the remote 5x4090D (via SSH tunnel) ---
# OPENAI_BASE_URL=http://127.0.0.1:8000/v1
# OPENAI_API_KEY=EMPTY
# LLM_MODEL=Qwen2.5-7B-Instruct

# --- Local Ollama ---
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# LLM_MODEL=qwen2.5

# --- retrieval / agent knobs ---
TOP_K=5
MAX_SEARCH_ROUNDS=3
USE_RID=1
